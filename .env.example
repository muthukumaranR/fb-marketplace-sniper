# Email notifications (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
NOTIFY_EMAIL=your-email@example.com

# Redis (Celery broker) — docker-compose overrides this to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# Default search location
DEFAULT_LOCATION=Huntsville, AL
DEFAULT_RADIUS=20

# Deal thresholds (percentage of fair price)
GREAT_DEAL_THRESHOLD=0.60
GOOD_DEAL_THRESHOLD=0.75

# Facebook cookie storage
FB_STATE_PATH=~/.config/sniper/fb_state.json

# LLM API keys (for price fallback via LiteLLM) — set at least one
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Scan frequency (minutes)
SCAN_INTERVAL_MINUTES=30
